@app/src/main/AndroidManifest.xml
<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
	<uses-feature android:name="android.hardware.touchscreen" android:required="false" />
	<uses-feature android:name="android.software.leanback" android:required="false" />
	<uses-permission android:name="android.permission.INTERNET" />
	<uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
	<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
	<application
		android:label="仏琰"
		android:icon="@mipmap/icon" android:banner="@drawable/banner"
		android:theme="@style/Theme.Fyan" android:allowBackup="true"
		android:hardwareAccelerated="true" android:largeHeap="false">
		<provider
			android:name="androidx.core.content.FileProvider"
			android:authorities="com.fyan.fileprovider"
			android:exported="false" android:grantUriPermissions="true">
			<meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/paths" />
		</provider>
		<activity
			android:name="com.fyan.O" android:exported="true"
			android:theme="@style/Theme.Fyan" android:launchMode="singleTop"
			android:windowSoftInputMode="adjustResize" android:enableOnBackInvokedCallback="true"
			android:configChanges="orientation|screenSize|screenLayout|smallestScreenSize|keyboard|keyboardHidden|navigation">
			<intent-filter>
				<action android:name="android.intent.action.MAIN" />
				<category android:name="android.intent.category.LAUNCHER" />
			</intent-filter>
			<intent-filter>
				<action android:name="android.intent.action.MAIN" />
				<category android:name="android.intent.category.LEANBACK_LAUNCHER" />
			</intent-filter>
		</activity>
	</application>
</manifest>

@app/src/main/res/xml/paths.xml
<?xml version="1.0" encoding="utf-8"?>
<paths>
	<external-files-path name="downloads" path="Download/" />
</paths>

@app/src/main/res/values/themes.xml
<resources>
	<style name="Theme.Fyan" parent="android:Theme.DeviceDefault.Light.NoActionBar">
		<!-- 状态栏 / 导航栏透明，由 Compose WindowInsets 统一控制 -->
		<item name="android:statusBarColor">@android:color/transparent</item>
		<item name="android:navigationBarColor">@android:color/transparent</item>
		<!-- 亮色图标（深色文字/图标在白色背景上） -->
		<item name="android:windowLightStatusBar">true</item>
		<item name="android:windowLightNavigationBar">true</item>
		<!-- 允许内容绘制到系统栏区域（edge-to-edge 基础） -->
		<item name="android:fitsSystemWindows">false</item>
		<!-- 刘海屏：内容延伸到刘海区域 -->
		<item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
		<!-- 启动画面背景色（冷启动闪屏） -->
		<item name="android:windowBackground">@android:color/white</item>
	</style>
</resources>

