@build.gradle.kts
plugins {
	id("com.android.library") version "8.13.2" apply false
	id("com.android.application") version "8.13.2" apply false
	id("org.jetbrains.kotlin.android") version "2.3.10" apply false
	id("org.jetbrains.kotlin.plugin.compose") version "2.3.10" apply false
}

@app/build.gradle.kts
plugins {
	id("com.android.application")
	id("org.jetbrains.kotlin.android")
	id("org.jetbrains.kotlin.plugin.compose")
}
android {
	namespace = "com.fyan"
	compileSdk = 36
	signingConfigs {
		create("release") {
			val e = System.getenv("KS_PATH")
			storeFile = if (!e.isNullOrEmpty()) file(e) else file("../fyan.keystore")
			storePassword = System.getenv("KS_PSWD") ?: ""
			keyAlias = System.getenv("K_ALIAS") ?: ""
			keyPassword = System.getenv("K_PSWD") ?: ""
		}
	}
	defaultConfig {
		applicationId = "com.fyan"
		minSdk = 23
		targetSdk = 36
		versionCode = 0
		versionName = "0"
		vectorDrawables { useSupportLibrary = true }
	}
	buildTypes {
		debug {
			isMinifyEnabled = false
			isShrinkResources = false
		}
		release {
			isMinifyEnabled = true
			isShrinkResources = true
			signingConfig = signingConfigs.getByName("release")
			proguardFiles(getDefaultProguardFile("proguard-android-optimize.txt"), "proguard-rules.pro")
		}
	}
	compileOptions {
		sourceCompatibility = JavaVersion.VERSION_17
		targetCompatibility = JavaVersion.VERSION_17
	}
	buildFeatures { compose = true }
	packaging {
		resources { excludes += "/META-INF/{AL2.0,LGPL2.1}" }
		jniLibs { keepDebugSymbols += "**/libandroidx.graphics.path.so" }
	}
}
kotlin {
	compilerOptions {
		jvmTarget.set(org.jetbrains.kotlin.gradle.dsl.JvmTarget.JVM_17)
	}
}
dependencies {
	// Compose BOM — 统一管理所有 compose.* 及 navigation-compose 版本
	implementation(platform("androidx.compose:compose-bom:2026.05.00"))
	// AndroidX 核心
	implementation("androidx.core:core-ktx:1.15.0")
	implementation("androidx.activity:activity-compose:1.13.0")
	implementation("androidx.lifecycle:lifecycle-runtime-ktx:2.10.0")
	// Compose UI（版本由 BOM 管理，无需显式声明）
	implementation("androidx.compose.ui:ui")
	implementation("androidx.compose.foundation:foundation")
	implementation("androidx.navigation:navigation-compose")
	// Media3（纯播放器核心，无 Material/AppCompat 依赖）
	implementation("androidx.media3:media3-exoplayer:1.10.1")
	implementation("androidx.media3:media3-exoplayer-hls:1.10.1")
	// Coil 3 图片加载
	implementation("io.coil-kt.coil3:coil-compose:3.4.0")
	implementation("io.coil-kt.coil3:coil-network-okhttp:3.4.0")
	// 开发工具
	debugImplementation("androidx.compose.ui:ui-tooling")
}

@settings.gradle.kts
pluginManagement {
	repositories {
		google()
		mavenCentral()
		gradlePluginPortal()
	}
	resolutionStrategy {
		eachPlugin {
			if (requested.id.id.startsWith("org.jetbrains.kotlin")) {
				useVersion("2.3.10")
			}
		}
	}
}
dependencyResolutionManagement {
	repositoriesMode.set(RepositoriesMode.FAIL_ON_PROJECT_REPOS)
	repositories {
		google()
		mavenCentral()
	}
}
rootProject.name = "fyan"
include(":app")

@gradle.properties
android.useAndroidX=true
android.enableJetifier=false
android.enableR8.fullMode=true
org.gradle.jvmargs=-Xmx4g -XX:MaxMetaspaceSize=1024m -XX:+UseG1GC
org.gradle.parallel=true
org.gradle.caching=true
org.gradle.configuration-cache=true
kotlin.incremental=true
kotlin.parallel.tasks.in.project=true

@app/proguard-rules.pro
# ── Kotlin ─────────────────────
-keep class kotlin.Metadata { *; }
-dontwarn kotlin.**
-dontwarn kotlinx.**
-keepclassmembers class **$WhenMappings { <fields>; }
-keepclassmembers class kotlin.Lazy { *; }
# ── Coroutines ──────────────────
-keepnames class kotlinx.coroutines.internal.MainDispatcherFactory { *; }
-keepnames class kotlinx.coroutines.CoroutineExceptionHandler { *; }
-keepclassmembernames class kotlinx.** {
	volatile <fields>;
}
# ── Compose ───────────────────
-keepclassmembers class * {
	@androidx.compose.runtime.Composable *;
}
-keep class androidx.compose.runtime.** { *; }
# ── Navigation Compose（序列化路由参数）─────
-keepnames class * implements androidx.navigation.NavArgs
-keepclassmembers class * implements androidx.navigation.NavArgs { *; }
# ── Media3 / ExoPlayer ──────────────
-keep class androidx.media3.** { *; }
-dontwarn androidx.media3.**
-keepclassmembers class androidx.media3.exoplayer.** { *; }
# ── OkHttp / Okio（Coil 网络后端）─────────
-dontwarn okhttp3.**
-dontwarn okio.**
-keep class okhttp3.internal.publicsuffix.PublicSuffixDatabase { *; }
-keepnames class okhttp3.** { *; }
# ── Coil 3 ────────────────────
-keep class coil3.** { *; }
-dontwarn coil3.**
