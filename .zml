@build.gradle.kts
plugins {
	id("com.android.library") version "8.9.1" apply false
	id("com.android.application") version "8.9.1" apply false
	id("org.jetbrains.kotlin.android") version "2.1.20" apply false
	id("org.jetbrains.kotlin.plugin.compose") version "2.1.20" apply false
}

@app/build.gradle.kts
plugins {
	id("com.android.application")
	id("org.jetbrains.kotlin.android")
	id("org.jetbrains.kotlin.plugin.compose")
}
android {
	namespace = "com.fyan"
	compileSdk = 36
	signingConfigs {
		create("release") {
			val e = System.getenv("KS_PATH")
			storeFile = if (!e.isNullOrEmpty()) file(e) else file("../fyan.keystore")
			storePassword = System.getenv("KS_PSWD") ?: ""
			keyAlias = System.getenv("K_ALIAS") ?: ""
			keyPassword = System.getenv("K_PSWD") ?: ""
		}
	}
	defaultConfig {
		applicationId = "com.fyan"
		minSdk = 23
		targetSdk = 36
		versionCode = 1
		versionName = "1.0"
		testInstrumentationRunner = "androidx.test.runner.AndroidJUnitRunner"
		vectorDrawables { useSupportLibrary = true }
	}
	sourceSets {
		getByName("main") {
			res.srcDirs("src/main/res")
		}
	}
	buildTypes {
		debug {
			isMinifyEnabled = false
			isShrinkResources = false
		}
		release {
			isMinifyEnabled = true
			isShrinkResources = true
			signingConfig = signingConfigs.getByName("release")
			proguardFiles(getDefaultProguardFile("proguard-android-optimize.txt"),"proguard-rules.pro")
		}
	}
	compileOptions {
		sourceCompatibility = JavaVersion.VERSION_17
		targetCompatibility = JavaVersion.VERSION_17
	}
	kotlin {
		compilerOptions {
			jvmTarget.set(org.jetbrains.kotlin.gradle.dsl.JvmTarget.JVM_17)
		}
	}
	buildFeatures { compose = true }
	packaging {
		resources { excludes += "/META-INF/{AL2.0,LGPL2.1}" }
		jniLibs { keepDebugSymbols += "**/libandroidx.graphics.path.so" }
	}
}
dependencies {
	// 基础 Compose BOM (2026.05.00 最稳定)
	val composeBom = platform("androidx.compose:compose-bom:2026.05.00")
	implementation(composeBom)
	// AndroidX 核心与生命周期
	implementation("androidx.core:core-ktx:1.19.0")
	implementation("androidx.activity:activity-compose:1.13.0")
	implementation("androidx.lifecycle:lifecycle-runtime-ktx:2.10.0")
	implementation("androidx.navigation:navigation-compose:2.8.8") // 这个版本目前依然适用
	// Compose UI 与基础组件 (由 BOM 管理)
	implementation("androidx.compose.ui:ui")
	implementation("androidx.compose.ui:ui-graphics")
	implementation("androidx.compose.foundation:foundation")
	// Media3 流媒体库
	implementation("androidx.media3:media3-exoplayer:1.10.1")
	implementation("androidx.media3:media3-exoplayer-hls:1.10.1")
	implementation("androidx.media3:media3-ui:1.10.1")
	// Coil 3 图片加载库核心与 Compose 扩展模块
	implementation("io.coil-kt.coil3:coil-compose:3.4.0")
	// 网络引擎模块，否则无法加载 URL 图片
	implementation("io.coil-kt.coil3:coil-network-okhttp:3.4.0")
	// 开发工具
	debugImplementation("androidx.compose.ui:ui-tooling")
}

@settings.gradle.kts
pluginManagement {
	repositories {
		google()
		mavenCentral()
		gradlePluginPortal()
	}
}
dependencyResolutionManagement {
	repositoriesMode.set(RepositoriesMode.FAIL_ON_PROJECT_REPOS)
	repositories {
		google()
		mavenCentral()
	}
}
rootProject.name = "fyan"
include(":app")

@gradle.properties
android.useAndroidX=true
android.enableJetifier=false
org.gradle.jvmargs=-Xmx4g -XX:MaxMetaspaceSize=1024m -XX:+UseG1GC
org.gradle.parallel=true
org.gradle.caching=true
org.gradle.configuration-cache=true
kotlin.incremental=true
kotlin.parallel.tasks.in.project=true
kotlin.compiler.execution.strategy=in-process
